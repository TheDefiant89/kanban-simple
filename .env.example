# Copy this file to .env.local for local development.
# Get these values from your Supabase project: Project Settings -> API.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: override the Vite base path used for GitHub Pages deployment.
# Defaults to "/kanban-simple/" (matching the repo name). Only needed if
# you rename the repository or deploy elsewhere.
# VITE_BASE_PATH=/kanban-simple/
